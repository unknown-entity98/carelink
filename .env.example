# CareLink — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Your Supabase project URL (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe to expose to browser — RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_.
# Used in API routes to bypass RLS for authorised server-side operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── AI Provider ───────────────────────────────────────────────────────────────
# AI backend to use: 'groq' (default) or 'ollama' (production/AU data sovereignty)
PROVIDER=groq

# Groq API key — SERVER ONLY. Required when PROVIDER=groq.
# Get your key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Ollama server URL — Required when PROVIDER=ollama.
# For production, point this to an Ollama instance on an Australian server.
# OLLAMA_URL=http://localhost:11434
